      ListItem ( "%clk" )
      ListItem ( "%enable_r" ) ) { .Map } : ( !seq.firmem < 4 x 8 > , i2 , !seq.clock , i1 , .Types ) -> ( i8 , .Types )  "seq.firmem.write_port" ( ListItem ( "%mem" )
      ListItem ( "%addr_w" )
      ListItem ( "%clk" )
      ListItem ( "%enable_w" )
      ListItem ( "%data_in_w" ) ) { "operandSegmentSizes" |-> array < i32 : 1 , 1 , 1 , 1 , 1 , 0 , .AttributeValueList > } : ( !seq.firmem < 4 x 8 > , i2 , !seq.clock , i1 , i8 , .Types ) -> ( .Types )  "hw.output" ( ListItem ( "%read_data" ) ) { .Map } : ( i8 , .Types ) -> ( .Types )  .StdOps  .StdBlocks } , .StdRegions ) : ( .Types ) -> ( .Types )
