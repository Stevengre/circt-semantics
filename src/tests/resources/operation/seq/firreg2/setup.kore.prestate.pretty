      ( "name" |-> "reg_port2" ) } : ( i8 , !seq.clock , i1 , i8 , .Types ) -> ( i8 , .Types )  "hw.output" ( ListItem ( "%3" )
      ListItem ( "%0" )
      ListItem ( "%5" ) ) { .Map } : ( i8 , i8 , i8 , .Types ) -> ( .Types )  .StdOps  .StdBlocks } , .StdRegions ) : ( .Types ) -> ( .Types )
