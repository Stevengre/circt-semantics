      "parameters" |-> [ .AttributeValueList ]
      "result_locs" |-> [ #loc , .AttributeValueList ]
      ( "sym_name" |-> "Foo" ) } [ .Successors ] ( { ^bb0 ( ListItem ( "%arg0" )
      ListItem ( "%arg1" ) ) : ListItem ( "%0" ) = "hw.array_create" ( ListItem ( "%arg0" ) ) { .Map } : ( i8 , .Types ) -> ( !hw.array < 1x i8 > , .Types )  ListItem ( "%1" ) = "hw.array_create" ( ListItem ( "%arg1" ) ) { .Map } : ( i8 , .Types ) -> ( !hw.array < 1x i8 > , .Types )  ListItem ( "%2" ) = "hw.array_concat" ( ListItem ( "%0" )
      ListItem ( "%1" ) ) { .Map } : ( !hw.array < 1x i8 > , !hw.array < 1x i8 > , .Types ) -> ( !hw.array < 2x i8 > , .Types )  ListItem ( "%3" ) = "hw.constant" ( .List ) { "value" |-> false } : ( .Types ) -> ( i1 , .Types )  ListItem ( "%4" ) = "hw.constant" ( .List ) { "value" |-> true } : ( .Types ) -> ( i1 , .Types )  ListItem ( "%5" ) = "hw.array_get" ( ListItem ( "%2" )
      ListItem ( "%3" ) ) { .Map } : ( !hw.array < 2x i8 > , i1 , .Types ) -> ( i8 , .Types )  ListItem ( "%6" ) = "hw.array_get" ( ListItem ( "%2" )
      ListItem ( "%4" ) ) { .Map } : ( !hw.array < 2x i8 > , i1 , .Types ) -> ( i8 , .Types )  ListItem ( "%7" ) = "comb.add" ( ListItem ( "%5" )
      ListItem ( "%6" ) ) { .Map } : ( i8 , i8 , .Types ) -> ( i8 , .Types )  "hw.output" ( ListItem ( "%7" ) ) { .Map } : ( i8 , .Types ) -> ( .Types )  .StdOps  .StdBlocks } , .StdRegions ) : ( .Types ) -> ( .Types )
    </table>
