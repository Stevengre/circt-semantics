      "Foo/%1" |-> "hw.array_create" ( ListItem ( "Foo/%arg1" ) ) { .Map } : ( i8 , .Types ) -> ( !hw.array < 1x i8 > , .Types )
      "Foo/%2" |-> "hw.array_concat" ( ListItem ( "Foo/%0" )
      ListItem ( "Foo/%1" ) ) { .Map } : ( !hw.array < 1x i8 > , !hw.array < 1x i8 > , .Types ) -> ( !hw.array < 2x i8 > , .Types )
      "Foo/%3" |-> "hw.constant" ( .List ) { "value" |-> false } : ( .Types ) -> ( i1 , .Types )
      "Foo/%4" |-> "hw.constant" ( .List ) { "value" |-> true } : ( .Types ) -> ( i1 , .Types )
      "Foo/%5" |-> "hw.array_get" ( ListItem ( "Foo/%2" )
      ListItem ( "Foo/%3" ) ) { .Map } : ( !hw.array < 2x i8 > , i1 , .Types ) -> ( i8 , .Types )
      "Foo/%6" |-> "hw.array_get" ( ListItem ( "Foo/%2" )
      ListItem ( "Foo/%4" ) ) { .Map } : ( !hw.array < 2x i8 > , i1 , .Types ) -> ( i8 , .Types )
      "Foo/%7" |-> "comb.add" ( ListItem ( "Foo/%5" )
      ListItem ( "Foo/%6" ) ) { .Map } : ( i8 , i8 , .Types ) -> ( i8 , .Types )
    </connection>
