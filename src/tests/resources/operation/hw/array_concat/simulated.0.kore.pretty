          ListItem ( "Foo/%3" ) ~> "hw.array_get" ( ListItem ( "Foo/%2" )
          ListItem ( "Foo/%3" ) ) { .Map } : ( !hw.array < 2x i8 > , i1 , .Types ) -> ( i8 , .Types ) ~> "HARDWARE#WRITE" ~> ListItem ( "Foo/%5" ) ~> ListItem ( "Foo/%7" )
          ListItem ( "Foo/%0" )
