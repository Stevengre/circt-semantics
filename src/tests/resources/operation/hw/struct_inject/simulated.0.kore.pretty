      ListItem ( "%3#1" ) = "hw.struct_explode" ( ListItem ( "%2" ) ) { .Map } : ( !hw.struct < a : i8 , b : i8 , .BareIdAndTypeList > , .Types ) -> ( i8 , i8 , .Types )  ListItem ( "%4" ) = "comb.add" ( ListItem ( "%3#0" )
      ListItem ( "%3#1" ) ) { .Map } : ( i8 , i8 , .Types ) -> ( i8 , .Types )  "hw.output" ( ListItem ( "%4" ) ) { .Map } : ( i8 , .Types ) -> ( .Types )  .StdOps  .StdBlocks } , .StdRegions ) : ( .Types ) -> ( .Types )
    </table>
