      "parameters" |-> [ .AttributeValueList ]
      "result_locs" |-> [ #loc , .AttributeValueList ]
      ( "sym_name" |-> "Foo" ) } [ .Successors ] ( { ^bb0 ( ListItem ( "%arg0" )
      ListItem ( "%arg1" ) ) : ListItem ( "%0" ) = "hw.struct_create" ( ListItem ( "%arg1" )
      ListItem ( "%arg0" ) ) { .Map } : ( i8 , i8 , .Types ) -> ( !hw.struct < a : i8 , b : i8 , .BareIdAndTypeList > , .Types )  ListItem ( "%1" ) = "hw.struct_inject" ( ListItem ( "%0" )
