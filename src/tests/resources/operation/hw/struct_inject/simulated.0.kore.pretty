      "Foo/%2" |-> "hw.struct_inject" ( ListItem ( "Foo/%1" )
      ListItem ( "Foo/%arg1" ) ) { "fieldIndex" |-> 1 : i32 } : ( !hw.struct < a : i8 , b : i8 , .BareIdAndTypeList > , i8 , .Types ) -> ( !hw.struct < a : i8 , b : i8 , .BareIdAndTypeList > , .Types )
