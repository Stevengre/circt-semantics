<teq>
  <mlir>
    <prog>
      .K
    </prog>
    <types>
      .Map
    </types>
    <attrs>
      #loc |-> loc ( "comb/icmp/icmp.mlir" : 1 : 42 )
    </attrs>
    <table>
      "Foo" |-> "hw.module" ( .List ) { ( "module_type" |-> !hw.modty < input a : i8 , input b : i8 , output res : i1 , .ModulePortList > )
      "parameters" |-> [ .AttributeValueList ]
      "result_locs" |-> [ #loc , .AttributeValueList ]
      ( "sym_name" |-> "Foo" ) } [ .Successors ] ( { ^bb0 ( ListItem ( "%arg0" )
      ListItem ( "%arg1" ) ) : ListItem ( "%0" ) = "comb.icmp" ( ListItem ( "%arg0" )
      ListItem ( "%arg1" ) ) { ( "predicate" |-> 0 : i64 )
      ( "twoState" |-> "" ) } : ( i8 , i8 , .Types ) -> ( i1 , .Types )  "hw.output" ( ListItem ( "%0" ) ) { .Map } : ( i1 , .Types ) -> ( .Types )  .StdOps  .StdBlocks } , .StdRegions ) : ( .Types ) -> ( .Types )
    </table>
    <symbols>
      .List
    </symbols>
  </mlir>
  <hardware>
    <setup>
      .K
    </setup>
    <connection>
      "Foo/%0" |-> "comb.icmp" ( ListItem ( "Foo/%arg0" )
      ListItem ( "Foo/%arg1" ) ) { ( "predicate" |-> 0 : i64 )
      ( "twoState" |-> "" ) } : ( i8 , i8 , .Types ) -> ( i1 , .Types )
    </connection>
    <procedures>
      .List
    </procedures>
    <signals>
      "Foo/%arg0" |-> bits ( 117 , 8 )
      "Foo/%arg1" |-> bits ( 76 , 8 )
    </signals>
    <history>
      .Map
    </history>
    <currents>
      <current-info>
        <current-id>
          0
        </current-id>
        <current>
          "comb.icmp" ( ListItem ( bits ( 117 , 8 ) )
          ListItem ( bits ( 76 , 8 ) ) ) { ( "predicate" |-> 0 : i64 )
          ( "twoState" |-> "" ) } : ( i8 , i8 , .Types ) -> ( i1 , .Types ) ~> "HARDWARE#WRITE" ~> ListItem ( "Foo/%0" ) ~> .List ~> .K
        </current>
      </current-info>
    </currents>
    <clock>
      0
    </clock>
  </hardware>
  <circt>
    <cmd>
      .K
    </cmd>
    <top-module>
      "Foo"
    </top-module>
    <top-ins>
      ListItem ( "Foo/%arg0" )
      ListItem ( "Foo/%arg1" )
    </top-ins>
  </circt>
  <hw>
    <hw-instances>
      <hw-instance>
        <hw-id>
          "Foo"
        </hw-id>
        <hw-module>
          "Foo"
        </hw-module>
        <hw-inputs>
          ListItem ( a )
          ListItem ( b )
        </hw-inputs>
        <hw-inports>
          ListItem ( "Foo/%arg0" )
          ListItem ( "Foo/%arg1" )
        </hw-inports>
        <hw-in-types>
          ListItem ( i8 )
          ListItem ( i8 )
        </hw-in-types>
        <hw-outputs>
          ListItem ( res )
        </hw-outputs>
        <hw-outports>
          ListItem ( "Foo/%0" )
        </hw-outports>
        <hw-out-types>
          ListItem ( i1 )
        </hw-out-types>
      </hw-instance>
      <hw-setup-inst>
        .List
      </hw-setup-inst>
    </hw-instances>
  </hw>
</teq>
