<teq>
  <mlir>
    <prog>
      .K
    </prog>
    <types>
      .Map
    </types>
    <attrs>
      #loc1 |-> loc ( "circt-semantics/src/tests/resources/modules/adder/adder.mlir" : 1 : 67 )
      #loc |-> loc ( "circt-semantics/src/tests/resources/modules/adder/adder.mlir" : 1 : 50 )
    </attrs>
    <table>
      "Adder" |-> "hw.module" ( .List ) { ( "module_type" |-> !hw.modty < input io_a : i8 , input io_b : i8 , output res_add : i8 , output res_sub : i8 , .ModulePortList > )
      "parameters" |-> [ .AttributeValueList ]
      "result_locs" |-> [ #loc , #loc1 , .AttributeValueList ]
      ( "sym_name" |-> "Adder" ) } [ .Successors ] ( { ^bb0 ( ListItem ( "%arg0" )
      ListItem ( "%arg1" ) ) : ListItem ( "%0" ) = "comb.add" ( ListItem ( "%arg0" )
      ListItem ( "%arg1" ) ) { .Map } : ( i8 , i8 , .Types ) -> ( i8 , .Types )  ListItem ( "%1" ) = "comb.sub" ( ListItem ( "%arg0" )
      ListItem ( "%arg1" ) ) { .Map } : ( i8 , i8 , .Types ) -> ( i8 , .Types )  "hw.output" ( ListItem ( "%0" )
      ListItem ( "%1" ) ) { .Map } : ( i8 , i8 , .Types ) -> ( .Types )  .StdOps  .StdBlocks } , .StdRegions ) : ( .Types ) -> ( .Types )
    </table>
    <symbols>
      .List
    </symbols>
  </mlir>
  <hardware>
    <setup>
      .K
    </setup>
    <connection>
      .Map
    </connection>
    <procedures>
      .List
    </procedures>
    <signals>
      .Map
    </signals>
    <history>
      .Map
    </history>
    <currents>
      .CurrentInfoCellMap
    </currents>
    <clock>
      0
    </clock>
  </hardware>
  <circt>
    <cmd>
      .K
    </cmd>
    <top-module>
      ""
    </top-module>
    <top-ins>
      .List
    </top-ins>
  </circt>
  <hw>
    <hw-instances>
      .HwInstanceCellMap
      <hw-setup-inst>
        .List
      </hw-setup-inst>
    </hw-instances>
  </hw>
</teq>
